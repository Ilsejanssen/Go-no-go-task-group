from psychopy import visual, core, event, data
import random
import csv

#ASK PARTICIPANT INPUT
info = {"participant": ""}
dlg = gui.DlgFromDict(info)
if not dlg.OK:
    core.quit()
name = info["participant"]

#create window
win = visual.Window(
    size= (800, 600),
    color="gray",
    units="height")
#introduction:
welcome_message = visual.TextStim(
                win,
                text = """Welcome to the experiment.
                Please press the SPACEBAR when you see 'GO', and do NOT press any keys when you see 'N0-GO'
                Please press the SPACEBAR to continue""",
                color = "black",
                height = 0.05
                )
#show instructions:
welcome_message.draw()
win.flip()
event.waitKeys(keyList = ["space"])

#  Create Stimuli
# Gekleurde rechthoek als achtergrond
rect = visual.Rect(
    win,
    width=0.5,
    height=0.3,
    fillColor="green",  # standaard, wordt per trial aangepast
    lineColor=None
)

# 2. Create Stimulus
stim = visual.TextStim(win, text="", height=0.2, color="white")

# 3. Create Trial List
go_trials = 4
nogo_trials = 1

trials = ["GO"] * go_trials + ["NOGO"] * nogo_trials
random.shuffle(trials)

# 4. Prepare Data Storage

data_file = open("data.csv", mode="w", newline="")
writer = csv.writer(data_file)
writer.writerow(["Name", "trial_type", "response", "reaction_time"])


# 5. Trial Loop

clock = core.Clock()

for trial in trials:

    # Set stimulus text
    if trial == "GO":
        stim.text = "Go"
        rect.fillColor = "green"
    else:
        stim.text = "No go"
        rect.fillColor = "red"

# Draw stimulus
    rect.draw()
    stim.draw()
    win.flip()

    clock.reset()
    keys = event.waitKeys(maxWait=1.0, keyList=["space"], timeStamped=clock)

# Check response
    if keys:
        response = "space"
        rt = keys[0][1]
    else:
        response = "none"
        rt = None


# Save trial data
    writer.writerow([name, trial, response, rt])

# Inter-trial interval
    win.flip()
    core.wait(0.5)

#end message
end_message = visual.TextStim(
win,
text = """This is the end of the experiment. Thank you for participating.""",
color = "black",
height = 0.05
)

#show instructions:
end_message.draw()
win.flip()

# 6. Clean Up

data_file.close()
win.close()
core.quit()

