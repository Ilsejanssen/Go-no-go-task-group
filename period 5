from psychopy import visual, core, event, data
import random
import csv

#create window
win = visual.Window(
    size= (800, 600),
    color="gray",
    units="height")
#introduction:
welcome_message = visual.TextStim(
                win,
                text = """Welcome to the experiment.
                Please press the SPACEBAR when you see 'GO', and do NOT press any keys when you see 'N0-GO'
                Please press the SPACEBAR to continue""",
                color = "black",
                height = 0.05
                )

#  Create Stimuli
# Gekleurde rechthoek als achtergrond
rect = visual.Rect(
    win,
    width=0.5,
    height=0.3,
    fillColor="green",  # standaard, wordt per trial aangepast
    lineColor=None
)

# 2. Create Stimulus
stim = visual.TextStim(win, text="", height=0.2, color="white")

# 3. Create Trial List
go_trials = 40
nogo_trials = 10

trials = ["GO"] * go_trials + ["NOGO"] * nogo_trials
random.shuffle(trials)





# 5. Trial Loop

clock = core.Clock()

for trial in trials:

    # Set stimulus text
    if trial == "GO":
        stim.text = "Go"
        rect.fillColor = "green"
    else:
        stim.text = "No go"
        rect.fillColor = "red"

# Draw stimulus
    rect.draw()
    stim.draw()
    win.flip()

    clock.reset()
    keys = event.waitKeys(maxWait=1.0, keyList=["space"], timeStamped=clock)

# Check response
    if keys:
        response = "space"
        rt = keys[0][1]
    else:
        response = "none"
        rt = None
# 4. Prepare Data Storage

data_file = open("data.csv", mode="w", newline="")
writer = csv.writer(data_file)
writer.writerow(["trial_type", "response", "reaction_time"])

# Save trial data
    writer.writerow([trial, response, rt])

# Inter-trial interval
    win.flip()
    core.wait(0.5)

# 6. Clean Up

data_file.close()
win.close()
core.quit()

